<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SpaceEdu - Reality</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@200;400;900&display=swap');

        body, html { margin: 0; padding: 0; background: #010409; color: white; font-family: 'Montserrat', sans-serif; overflow-x: hidden; }

        /* Navigation */
        nav { position: fixed; top: 0; width: 100%; display: flex; justify-content: space-between; padding: 30px 60px; z-index: 10; align-items: center; box-sizing: border-box; }
        .logo { font-weight: 900; letter-spacing: 5px; font-size: 1.2rem; }
        .links { display: flex; gap: 25px; }
        .links a { color: #fff; text-decoration: none; font-size: 0.8rem; opacity: 0.7; letter-spacing: 2px; }
        .enroll { border: 1px solid #ffffff40; background: rgba(255,255,255,0.05); color: white; padding: 10px 30px; border-radius: 30px; backdrop-filter: blur(5px); cursor: pointer; }

        /* Hero Content */
        .content { position: relative; z-index: 2; height: 200vh; pointer-events: none; }
        .section { height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 0 10%; box-sizing: border-box; }
        .section.left { align-items: flex-start; text-align: left; }

        .eyebrow { color: #4facfe; letter-spacing: 8px; font-size: 0.8rem; margin-bottom: 10px; }
        h1 { font-size: clamp(3rem, 10vw, 7rem); font-weight: 900; letter-spacing: 25px; margin: 0; line-height: 1; }
        .desc { max-width: 500px; opacity: 0.6; line-height: 1.8; margin-top: 20px; font-size: 0.9rem; }
        .btn { margin-top: 40px; padding: 15px 45px; border-radius: 50px; border: none; background: #fff; font-weight: 900; cursor: pointer; pointer-events: all; }

        /* 3D Canvas Container */
        #canvas-container { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; }
    </style>
</head>
<body>

    <nav>
        <div class="logo">SPACEEDU</div>
        <div class="links">
            <a href="#">PLANETS</a>
            <a href="#">TRAILER</a>
            <a href="#">TICKETS</a>
            <a href="#">BLOG</a>
        </div>
        <button class="enroll">Enroll</button>
    </nav>

    <div id="canvas-container"></div>

    <main class="content">
        <section class="section">
            <p class="eyebrow">PLANET</p>
            <h1>EARTH</h1>
            <p class="desc">Learn more about this fascinating miracle that we call our home, Planet Earth. Course enrollment starts today.</p>
            <button class="btn">GET STARTED</button>
        </section>

        <section class="section left">
            <p class="eyebrow">THE BLUE PLANET</p>
            <h1 style="font-size: 4rem; letter-spacing: 10px;">EARTH</h1>
            <p class="desc">Earth is the third planet from the sun. It is an ocean planet. Water covers 70% of Earth's surface.</p>
            <button class="btn" style="background: transparent; border: 1px solid white; color: white;">LEARN MORE</button>
        </section>
    </main>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

    <script>
        // 1. Setup Three.js Scene
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        document.getElementById('canvas-container').appendChild(renderer.domElement);

        // 2. Create Earth Sphere
        const geometry = new THREE.SphereGeometry(2, 64, 64);
        const textureLoader = new THREE.TextureLoader();
        // High quality earth texture
        const earthTexture = textureLoader.load('https://unpkg.com/three-globe/example/img/earth-blue-marble.jpg');
        const material = new THREE.MeshPhongMaterial({ 
            map: earthTexture,
            shininess: 5
        });
        const earth = new THREE.Mesh(geometry, material);
        scene.add(earth);

        // 3. Add Lights (Isse Earth real lagegi)
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.2);
        scene.add(ambientLight);

        const mainLight = new THREE.DirectionalLight(0xffffff, 1);
        mainLight.position.set(5, 3, 5);
        scene.add(mainLight);

        camera.position.z = 5;

        // 4. Scroll Animation (GSAP)
        gsap.registerPlugin(ScrollTrigger);

        const tl = gsap.timeline({
            scrollTrigger: {
                trigger: ".content",
                start: "top top",
                end: "bottom bottom",
                scrub: 1
            }
        });

        // Video wala transition: Earth side mein jayegi aur zoom hogi
        tl.to(earth.position, { x: 2.5, y: 0.5, z: 1 }, 0);
        tl.to(earth.rotation, { y: Math.PI }, 0);
        tl.to(".section:first-child", { opacity: 0, y: -50 }, 0);

        // 5. Animation Loop
        function animate() {
            requestAnimationFrame(animate);
            earth.rotation.y += 0.002; // Slow rotation like real earth
            renderer.render(scene, camera);
        }
        animate();

        // Handle Resize
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
    </script>
</body>
</html>
